{
  "name": "slithera",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "dev": "concurrently -k --handle-input -n SERVER,CLIENT -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "build": "npm run typecheck && vite build && tsc -p server/tsconfig.json",
    "preview": "npm run build && node dist-server/server/index.js",
    "start": "node dist-server/server/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "firebase": "^12.12.1",
    "lucide-react": "^0.561.0",
    "pixi.js": "^8.14.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "jsdom": "^27.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  }
}
