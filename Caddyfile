slithera.duckdns.org {
    # WS paths → game directly
    handle /ws* {
        reverse_proxy localhost:3001
    }

    # Admin API → game directly
    handle /admin/state {
        reverse_proxy localhost:3001
    }
    handle /admin/kick {
        reverse_proxy localhost:3001
    }
    handle /admin/broadcast {
        reverse_proxy localhost:3001
    }
    handle /admin/ban {
        reverse_proxy localhost:3001
    }
    handle /admin/unban {
        reverse_proxy localhost:3001
    }
    handle /health {
        reverse_proxy localhost:3001
    }

    # Everything else → nginx (static files + SPA)
    handle {
        reverse_proxy localhost:8080
    }
}
